# ============================================================
# Wildlife AI — Environment Variables Template
# ============================================================
# STEP 1: Copy this file:  cp .env.example .env
# STEP 2: Fill in your real credentials below
# STEP 3: NEVER commit .env to GitHub (it's in .gitignore)
# ============================================================

# ── Cloudinary (image storage) ─────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ── Google Firebase / Firestore (database) ─────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
# OR use a key file path (comment out the above 3 lines if using this):
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── Generative AI APIs (for wildlife report generation) ────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key
# Get from: https://platform.openai.com (optional fallback)
OPENAI_API_KEY=your-openai-api-key

# ── Service URLs ────────────────────────────────────────────
# URL of Node.js Firestore service (called by FastAPI)
NODE_SERVICE_URL=http://localhost:5001
# URL of FastAPI backend (called by React frontend)
VITE_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Model Paths ─────────────────────────────────────────────
MODEL_PATH=best_model.pth
CLASS_NAMES_PATH=class_names.json

# ── Node Service Port ───────────────────────────────────────
NODE_PORT=5001

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
